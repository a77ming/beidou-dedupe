{
  "name": "beidou-dedupe-tool",
  "private": true,
  "version": "0.1.3",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "node tools/dev.mjs",
    "build": "vite build",
    "test": "node tools/strategy_selftest.mjs",
    "start": "electron .",
    "build:processor:mac:arm64": "bash tools/build_processor_macos_arm64.sh",
    "build:processor:win": "tools\\build_processor_windows.bat",
    "pack": "node tools/ensure_processor.mjs && electron-builder --dir",
    "dist": "node tools/ensure_processor.mjs && electron-builder",
    "dist:mac:arm64": "npm run build && npm run build:processor:mac:arm64 && electron-builder --mac",
    "dist:win": "npm run build && npm run build:processor:win && electron-builder --win"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "electron": "^28.2.3",
    "electron-builder": "^24.9.1",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.ming.videodedupe",
    "productName": "北斗去重工具",
    "files": [
      "renderer/**/*",
      "electron/**/*",
      "tools/**/*",
      "processor/**/*",
      "config.json",
      "strategies.json",
      "strategies_to_validate.txt",
      "package.json"
    ],
    "asarUnpack": [
      "tools/**/*",
      "processor/**/*"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "extraResources": [
      {
        "from": "build/bin/video_dedupe_processor",
        "to": "processor-bin/video_dedupe_processor"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "extraResources": [
        {
          "from": "build/bin/video_dedupe_processor.exe",
          "to": "processor-bin/video_dedupe_processor.exe"
        }
      ]
    },
    "mac": {
      "icon": "build/icon.icns"
    }
  }
}
